# Optional per-machine overrides for run-dev-local.sh.
#
# Per-session config (model, system prompt, S3, connectors) does NOT live
# here anymore — it lives in local/demo_session.json (see
# local/demo_session.json.example for the template).
#
# Everything in this file is optional; copy to .env.local only if you
# need to override a default.

# Listen port (default 8080).
# AUGCHATD_PORT=8080

# Where per-conversation JSONL traces are appended. Unset disables tracing.
# run-dev-local.sh defaults this to ./data-trace.
# AUGCHATD_TRACE_DIR=./data-trace

# JWT lifetime in seconds (default 60). Bumping helps long local sessions.
# DEMO_TTL_SECONDS=1800

# Override the demo session config path (default local/demo_session.json).
# DEMO_SESSION_FILE=local/demo_session.json
